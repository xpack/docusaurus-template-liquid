  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/plugin-client-redirects": "3.10.0",
    "@docusaurus/plugin-ideal-image": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@docusaurus/theme-search-algolia": "3.10.0",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "$dependenciesUrls": {
    "del-cli": "https://www.npmjs.com/package/del-cli",
    "json": "https://www.npmjs.com/package/json",
    "liquidjs": "https://www.npmjs.com/package/liquidjs",
    "typescript": "https://www.npmjs.com/package/typescript"
  },
  "devDependencies": {
    "del-cli": "^7.0.0",
{%- if githubProjectOrganization == "micro-os-plus" %}
    "open-cli": "^8.0.0",
    "broken-link-checker": "^0.7.8",
{%- endif %}
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "json": "^11.0.0",
    "liquidjs": "^10.25.0",
{%- if isTypeScript == "true" %}
    "@xpack/tsdoc2docusaurus-cli": "^1.3.2",
    "@microsoft/api-documenter": "^7.28.2",
    "@microsoft/api-extractor": "^7.55.2",
{%- endif %}
    "@xpack/docusaurus-template-liquid": "github:xpack/docusaurus-template-liquid",
    "@xpack/npm-packages-helper": "github:xpack/npm-packages-helper",
    "typescript": "~5.9.3"
  },
  "scripts": {
    "generate-website-commons": "bash node_modules/@xpack/docusaurus-template-liquid/maintenance-scripts/generate-website-commons.sh --{{githubProjectOrganization}}",
    "npm-outdated": "npm outdated",
    "npm-install": "npm install",
    "npm-link-helpers": "npm link @xpack/docusaurus-template-liquid @xpack/npm-packages-helper",
    "npm-ci": "npm ci",
    "clean": "del-cli .docusaurus build",
    "deep-clean": "del-cli .docusaurus build node_modules package-lock.json",
{%- if packageWebsiteConfig.hasDoxygenReference == "true" %}
    "doxygen": "del-cli static/doxygen doxygen/xml; (cd doxygen; doxygen config.doxyfile)",
    "browse-doxygen": "open-cli static/doxygen/index.html",
{%- if packageWebsiteConfig.hasDoxygenDocusaurusApi == "true" %}
    "convert-doxygen": "doxygen2docusaurus",
    "generate-website-doxygen": "npm run doxygen && npm run convert-doxygen",
{%- endif %}
    "check-urls": "blc {{packageHomepage}} --recursive --ordered --filter-level 2 --exclude 'https://twitter.com*'",
{%- endif %}
{%- if packageWebsiteConfig.hasTSDocDocusaurusApi == "true" %}
    "compile-tsdoc": "del-cli --force tsdoc/dist && tsc --project config/tsconfig-api-extractor.json",
    "api-extractor-init": "api-extractor init",
    "api-extractor": "api-extractor run --local --verbose",
    "patch-doc-model-json": "bash config/patch-doc-model-json.sh tsdoc/doc-model/website.api.json website @xpack/xpm-lib",
    "api-documenter": "del-cli --force tsdoc/markdown && api-documenter markdown --input-folder tsdoc/doc-model --output-folder tsdoc/markdown",
    "tsdoc2docusaurus": "tsdoc2docusaurus --id website",
    "generate-website-tsdoc": "npm run compile-tsdoc && npm run api-extractor && npm run patch-doc-model-json && npm run api-documenter && npm run tsdoc2docusaurus",
{%- if hasBranchWebpreview == 'true' %}
    "tsdoc2docusaurus-webpreview": "tsdoc2docusaurus --id webpreview",
    "generate-webpreview-tsdoc": "npm run compile-tsdoc && npm run api-extractor && npm run patch-doc-model-json && npm run api-documenter && npm run tsdoc2docusaurus-webpreview",
{%- endif %}
{%- endif %}
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "import-website-releases": "bash node_modules/@xpack/docusaurus-template-liquid/maintenance-scripts/import-releases.sh --{{githubProjectOrganization}}",
{%- if githubProjectOrganization == "micro-os-plus" %}
    "generate-website-releases-from-tags": "bash node_modules/@xpack/docusaurus-template-liquid/maintenance-scripts/generate-releases-for-tags.sh --{{githubProjectOrganization}}",
{%- endif %}
    "generate-website-blog-post": "bash node_modules/@xpack/docusaurus-template-liquid/maintenance-scripts/generate-blog-post.sh --{{githubProjectOrganization}}",
    "generate-dependencies-details": "bash node_modules/@xpack/docusaurus-template-liquid/maintenance-scripts/generate-dependencies-details.sh --{{githubProjectOrganization}}"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
